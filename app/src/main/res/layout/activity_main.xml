<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#091627">

    <androidx.camera.view.PreviewView android:id="@+id/preview"
        android:layout_width="match_parent" android:layout_height="match_parent" android:visibility="gone" />

    <!-- SCAN OVERLAY -->
    <LinearLayout android:id="@+id/scanOverlay" android:layout_width="match_parent" android:layout_height="match_parent"
        android:orientation="vertical" android:visibility="gone">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="#E6091627" android:gravity="center_vertical" android:orientation="horizontal" android:padding="16dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="Scan paint can" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" />
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="#E6091627"
            android:orientation="horizontal" android:paddingStart="14dp" android:paddingEnd="14dp" android:paddingBottom="10dp">
            <Button android:id="@+id/btnModeCount" style="@style/Btn" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                android:layout_marginEnd="5dp" android:background="@drawable/btn_blue" android:text="📋 Inventory" android:textColor="#FFFFFF" android:textSize="13sp" />
            <Button android:id="@+id/btnModeMove" style="@style/Btn" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                android:layout_marginStart="5dp" android:background="@drawable/btn_dark" android:text="✏️ Adjust one" android:textColor="#FFFFFF" android:textSize="13sp" />
        </LinearLayout>
        <TextView android:id="@+id/tvScanInfo" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_margin="14dp" android:background="@drawable/banner_info" android:padding="14dp"
            android:text="Point at a paint can QR label" android:textColor="#9FC0E8" android:textSize="14sp" android:textStyle="bold" />
        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="#F2091627" android:orientation="vertical" android:padding="16dp">
            <LinearLayout android:id="@+id/countPanel" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:visibility="gone">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingBottom="6dp"
                    android:text="Counted this session (each label once)" android:textColor="#6E8AAE" android:textSize="12sp" android:textStyle="bold" />
                <ScrollView android:layout_width="match_parent" android:layout_height="150dp" android:background="@drawable/card" android:padding="10dp">
                    <LinearLayout android:id="@+id/countList" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" />
                </ScrollView>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingTop="8dp" android:paddingBottom="8dp">
                    <Button android:id="@+id/btnCountFinish" style="@style/Btn" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
                        android:layout_marginEnd="5dp" android:background="@drawable/btn_green" android:text="Finish &amp; apply" android:textColor="#FFFFFF" android:textSize="14sp" />
                    <Button android:id="@+id/btnCountReset" style="@style/Btn" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
                        android:layout_marginStart="5dp" android:background="@drawable/btn_red" android:text="Reset" android:textColor="#FFFFFF" android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>
            <TextView android:id="@+id/tvScanHint" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:paddingBottom="12dp" android:text="Scanning…" android:textColor="#9FC0E8" android:textSize="14sp" />
            <Button android:id="@+id/btnScanBack" style="@style/Btn" android:layout_width="match_parent" android:layout_height="50dp"
                android:background="@drawable/btn_dark" android:text="Back to menu" android:textColor="#FFFFFF" />
        </LinearLayout>
    </LinearLayout>

    <!-- HOME -->
    <ScrollView android:id="@+id/panelHome" android:layout_width="match_parent" android:layout_height="match_parent" android:fillViewport="true">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:gravity="center_horizontal" android:orientation="vertical" android:padding="22dp" android:paddingTop="36dp">
            <ImageView android:layout_width="120dp" android:layout_height="120dp"
                android:src="@drawable/app_logo" android:contentDescription="logo" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp"
                android:letterSpacing="0.06" android:text="ASPS PAINT STOCK" android:textColor="#FFFFFF" android:textSize="26sp" android:textStyle="bold" />
            <TextView android:id="@+id/tvHomeVessel" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="NAVIGATOR COPERNICO" android:textColor="#3FBE77" android:textSize="13sp" android:textStyle="bold" />
            <TextView android:id="@+id/tvHomeTotals" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="4dp" android:text="" android:textColor="#6E8AAE" android:textSize="12sp" />
            <View android:layout_width="match_parent" android:layout_height="22dp" />
            <Button android:id="@+id/btnScan" style="@style/Btn" android:layout_width="match_parent" android:layout_height="62dp"
                android:background="@drawable/btn_green" android:text="📷  SCAN / COUNT" android:textColor="#FFFFFF" android:textSize="17sp" />
            <Button android:id="@+id/btnList" style="@style/Btn" android:layout_width="match_parent" android:layout_height="54dp"
                android:layout_marginTop="12dp" android:background="@drawable/btn_dark" android:text="Stock list" android:textColor="#FFFFFF" android:textSize="15sp" />
            <Button android:id="@+id/btnReports" style="@style/Btn" android:layout_width="match_parent" android:layout_height="54dp"
                android:layout_marginTop="12dp" android:background="@drawable/btn_dark" android:text="Reports &amp; requisition" android:textColor="#FFFFFF" android:textSize="15sp" />
            <Button android:id="@+id/btnLabels" style="@style/Btn" android:layout_width="match_parent" android:layout_height="54dp"
                android:layout_marginTop="12dp" android:background="@drawable/btn_blue" android:text="🖨  Print QR labels" android:textColor="#FFFFFF" android:textSize="15sp" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:orientation="horizontal">
                <Button android:id="@+id/btnAdd" style="@style/Btn" android:layout_width="0dp" android:layout_height="54dp" android:layout_weight="1"
                    android:layout_marginEnd="6dp" android:background="@drawable/btn_dark" android:text="Add paint" android:textColor="#FFFFFF" android:textSize="14sp" />
                <Button android:id="@+id/btnSettings" style="@style/Btn" android:layout_width="0dp" android:layout_height="54dp" android:layout_weight="1"
                    android:layout_marginStart="6dp" android:background="@drawable/btn_dark" android:text="Settings" android:textColor="#FFFFFF" android:textSize="14sp" />
            </LinearLayout>
            <TextView android:id="@+id/tvVersion" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="20dp" android:text="native v1.0" android:textColor="#4A627E" android:textSize="11sp" />
        </LinearLayout>
    </ScrollView>

    <!-- ITEM (movement) -->
    <ScrollView android:id="@+id/panelItem" android:layout_width="match_parent" android:layout_height="match_parent"
        android:background="#091627" android:visibility="gone">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="18dp">
            <TextView android:id="@+id/tvItemTitle" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Item" android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold" />
            <TextView android:id="@+id/tvItemMeta" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="4dp" android:text="" android:textColor="#9FC0E8" android:textSize="13sp" />
            <TextView android:id="@+id/tvItemRob" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="14dp" android:background="@drawable/card" android:padding="16dp"
                android:text="" android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold" />

            <TextView style="@style/Lbl" android:layout_marginTop="18dp" android:text="SET CURRENT COUNT (cans)" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <EditText android:id="@+id/etSet" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:layout_marginTop="6dp" android:layout_marginEnd="8dp" android:background="@drawable/field" android:inputType="number"
                    android:padding="14dp" android:textColor="#FFFFFF" android:textColorHint="#5C7592" android:hint="cans" />
                <Button android:id="@+id/btnSet" style="@style/Btn" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="6dp" android:background="@drawable/btn_green" android:text="Set" android:textColor="#FFFFFF" android:minWidth="90dp" />
            </LinearLayout>

            <TextView style="@style/Lbl" android:layout_marginTop="18dp" android:text="OR MOVEMENT (cans)" />
            <EditText android:id="@+id/etMove" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="6dp" android:background="@drawable/field" android:inputType="number"
                android:padding="14dp" android:textColor="#FFFFFF" android:textColorHint="#5C7592" android:hint="cans" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:orientation="horizontal">
                <Button android:id="@+id/btnRcvd" style="@style/Btn" android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1"
                    android:layout_marginEnd="6dp" android:background="@drawable/btn_green" android:text="+ Received" android:textColor="#FFFFFF" />
                <Button android:id="@+id/btnSpent" style="@style/Btn" android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1"
                    android:layout_marginStart="6dp" android:background="@drawable/btn_red" android:text="– Spent" android:textColor="#FFFFFF" />
            </LinearLayout>

            <Button android:id="@+id/btnEditItem" style="@style/Btn" android:layout_width="match_parent" android:layout_height="50dp"
                android:layout_marginTop="20dp" android:background="@drawable/btn_blue" android:text="Edit details / min / price" android:textColor="#FFFFFF" />
            <Button android:id="@+id/btnItemBack" style="@style/Btn" android:layout_width="match_parent" android:layout_height="50dp"
                android:layout_marginTop="10dp" android:background="@drawable/btn_dark" android:text="Back" android:textColor="#FFFFFF" />
        </LinearLayout>
    </ScrollView>

    <!-- LIST -->
    <LinearLayout android:id="@+id/panelList" android:layout_width="match_parent" android:layout_height="match_parent"
        android:background="#091627" android:orientation="vertical" android:visibility="gone">
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:background="#0E2746"
            android:padding="18dp" android:text="Stock list" android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold" />
        <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:padding="12dp">
            <LinearLayout android:id="@+id/listContainer" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" />
        </ScrollView>
        <Button android:id="@+id/btnListBack" style="@style/Btn" android:layout_width="match_parent" android:layout_height="52dp"
            android:layout_margin="14dp" android:background="@drawable/btn_dark" android:text="Back" android:textColor="#FFFFFF" />
    </LinearLayout>

    <!-- ADD / EDIT -->
    <ScrollView android:id="@+id/panelAdd" android:layout_width="match_parent" android:layout_height="match_parent"
        android:background="#091627" android:visibility="gone">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
            <TextView android:id="@+id/tvAddTitle" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="#0E2746"
                android:padding="18dp" android:text="Add paint" android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="18dp">
                <TextView style="@style/Lbl" android:text="PRODUCT" />
                <EditText android:id="@+id/etProduct" style="@style/Field" android:hint="SIGMACOVER 350" android:inputType="textCapWords" />
                <TextView style="@style/Lbl" android:layout_marginTop="14dp" android:text="COLOUR" />
                <EditText android:id="@+id/etColor" style="@style/Field" android:hint="Grey" android:inputType="textCapWords" />
                <TextView style="@style/Lbl" android:layout_marginTop="14dp" android:text="COLOUR CODE" />
                <EditText android:id="@+id/etColorCode" style="@style/Field" android:hint="5177" android:inputType="text" />
                <TextView style="@style/Lbl" android:layout_marginTop="14dp" android:text="CATEGORY" />
                <Spinner android:id="@+id/spCategory" android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="6dp" android:background="@drawable/field" android:padding="12dp" />
                <TextView style="@style/Lbl" android:layout_marginTop="14dp" android:text="CAN VOLUME (litres)" />
                <EditText android:id="@+id/etCanVol" style="@style/Field" android:hint="20" android:inputType="numberDecimal" />
                <TextView style="@style/Lbl" android:layout_marginTop="14dp" android:text="THINNER (optional)" />
                <EditText android:id="@+id/etThinner" style="@style/Field" android:hint="91-92" android:inputType="text" />
                <TextView style="@style/Lbl" android:layout_marginTop="14dp" android:text="AREA / USE (optional)" />
                <EditText android:id="@+id/etArea" style="@style/Field" android:hint="Primer" android:inputType="textCapSentences" />
                <TextView style="@style/Lbl" android:layout_marginTop="14dp" android:text="QUANTITY (cans)" />
                <EditText android:id="@+id/etQty" style="@style/Field" android:hint="0" android:inputType="number" />
                <TextView style="@style/Lbl" android:layout_marginTop="14dp" android:text="MIN / RE-ORDER LEVEL (cans, 0=off)" />
                <EditText android:id="@+id/etMin" style="@style/Field" android:hint="0" android:inputType="number" />
                <TextView style="@style/Lbl" android:layout_marginTop="14dp" android:text="PRICE PER CAN (optional)" />
                <EditText android:id="@+id/etPrice" style="@style/Field" android:hint="0" android:inputType="numberDecimal" />
                <Button android:id="@+id/btnSaveItem" style="@style/Btn" android:layout_width="match_parent" android:layout_height="56dp"
                    android:layout_marginTop="18dp" android:background="@drawable/btn_green" android:text="SAVE" android:textColor="#FFFFFF" android:textSize="16sp" />
                <Button android:id="@+id/btnDeleteItem" style="@style/Btn" android:layout_width="match_parent" android:layout_height="50dp"
                    android:layout_marginTop="10dp" android:background="@drawable/btn_red" android:text="Delete this item" android:textColor="#FFFFFF" android:visibility="gone" />
                <Button android:id="@+id/btnAddBack" style="@style/Btn" android:layout_width="match_parent" android:layout_height="50dp"
                    android:layout_marginTop="10dp" android:background="@drawable/btn_dark" android:text="Back" android:textColor="#FFFFFF" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- REPORTS -->
    <ScrollView android:id="@+id/panelReports" android:layout_width="match_parent" android:layout_height="match_parent"
        android:background="#091627" android:visibility="gone">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:background="#0E2746"
                android:padding="18dp" android:text="Reports &amp; requisition" android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="18dp">
                <TextView style="@style/Lbl" android:text="INVENTORY REPORT" />
                <Button android:id="@+id/btnInvOpen" style="@style/Btn" android:layout_width="match_parent" android:layout_height="52dp"
                    android:layout_marginTop="6dp" android:layout_marginBottom="8dp" android:background="@drawable/btn_green" android:text="Open inventory PDF" android:textColor="#FFFFFF" />
                <Button android:id="@+id/btnInvShare" style="@style/Btn" android:layout_width="match_parent" android:layout_height="50dp"
                    android:layout_marginBottom="22dp" android:background="@drawable/btn_dark" android:text="Share inventory PDF" android:textColor="#FFFFFF" />
                <TextView style="@style/Lbl" android:text="CONSUMPTION (SINCE LAST INVENTORY)" />
                <Button android:id="@+id/btnConsOpen" style="@style/Btn" android:layout_width="match_parent" android:layout_height="52dp"
                    android:layout_marginTop="6dp" android:layout_marginBottom="8dp" android:background="@drawable/btn_blue" android:text="Open consumption PDF" android:textColor="#FFFFFF" />
                <Button android:id="@+id/btnConsShare" style="@style/Btn" android:layout_width="match_parent" android:layout_height="50dp"
                    android:layout_marginBottom="22dp" android:background="@drawable/btn_dark" android:text="Share consumption PDF" android:textColor="#FFFFFF" />
                <TextView style="@style/Lbl" android:text="REQUISITION / QUOTATION" />
                <Button android:id="@+id/btnQuoAuto" style="@style/Btn" android:layout_width="match_parent" android:layout_height="52dp"
                    android:layout_marginTop="6dp" android:layout_marginBottom="8dp" android:background="@drawable/btn_blue" android:text="Auto: items under minimum" android:textColor="#FFFFFF" />
                <Button android:id="@+id/btnQuoManual" style="@style/Btn" android:layout_width="match_parent" android:layout_height="52dp"
                    android:layout_marginBottom="22dp" android:background="@drawable/btn_blue" android:text="Manual: choose quantities" android:textColor="#FFFFFF" />
                <TextView style="@style/Lbl" android:text="QR LABELS" />
                <Button android:id="@+id/btnLabOpen" style="@style/Btn" android:layout_width="match_parent" android:layout_height="52dp"
                    android:layout_marginTop="6dp" android:layout_marginBottom="8dp" android:background="@drawable/btn_green" android:text="Open QR labels PDF" android:textColor="#FFFFFF" />
                <Button android:id="@+id/btnLabShare" style="@style/Btn" android:layout_width="match_parent" android:layout_height="50dp"
                    android:layout_marginBottom="22dp" android:background="@drawable/btn_dark" android:text="Share QR labels PDF" android:textColor="#FFFFFF" />
                <Button android:id="@+id/btnReportsBack" style="@style/Btn" android:layout_width="match_parent" android:layout_height="50dp"
                    android:background="@drawable/btn_dark" android:text="Back" android:textColor="#FFFFFF" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- REQUISITION (manual quantities) -->
    <LinearLayout android:id="@+id/panelReq" android:layout_width="match_parent" android:layout_height="match_parent"
        android:background="#091627" android:orientation="vertical" android:visibility="gone">
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:background="#0E2746"
            android:padding="18dp" android:text="Requisition — enter cans to order" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" />
        <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:padding="12dp">
            <LinearLayout android:id="@+id/reqContainer" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" />
        </ScrollView>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="14dp">
            <Button android:id="@+id/btnReqGen" style="@style/Btn" android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1"
                android:layout_marginEnd="6dp" android:background="@drawable/btn_green" android:text="Generate" android:textColor="#FFFFFF" />
            <Button android:id="@+id/btnReqBack" style="@style/Btn" android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1"
                android:layout_marginStart="6dp" android:background="@drawable/btn_dark" android:text="Back" android:textColor="#FFFFFF" />
        </LinearLayout>
    </LinearLayout>

    <!-- LABELS (select which to print) -->
    <LinearLayout android:id="@+id/panelLabels" android:layout_width="match_parent" android:layout_height="match_parent"
        android:background="#091627" android:orientation="vertical" android:visibility="gone">
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:background="#0E2746"
            android:padding="18dp" android:text="Print QR labels" android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold" />
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_margin="12dp"
            android:background="@drawable/banner_info" android:padding="12dp"
            android:text="Tick the paints you want labels for (e.g. only the ones just received), then generate the QR file."
            android:textColor="#9FC0E8" android:textSize="13sp" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingStart="12dp" android:paddingEnd="12dp">
            <Button android:id="@+id/btnLblAll" style="@style/Btn" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="@drawable/btn_dark" android:text="All" android:textColor="#FFFFFF" android:textSize="13sp" />
            <Button android:id="@+id/btnLblNone" style="@style/Btn" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:layout_marginStart="4dp" android:layout_marginEnd="4dp" android:background="@drawable/btn_dark" android:text="None" android:textColor="#FFFFFF" android:textSize="13sp" />
            <Button android:id="@+id/btnLblStock" style="@style/Btn" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:layout_marginStart="4dp" android:layout_marginEnd="4dp" android:background="@drawable/btn_dark" android:text="In stock" android:textColor="#FFFFFF" android:textSize="13sp" />
            <Button android:id="@+id/btnLblLow" style="@style/Btn" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:layout_marginStart="4dp" android:background="@drawable/btn_dark" android:text="Below min" android:textColor="#FFFFFF" android:textSize="13sp" />
        </LinearLayout>
        <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:padding="12dp">
            <LinearLayout android:id="@+id/lblContainer" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" />
        </ScrollView>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="14dp">
            <Button android:id="@+id/btnLblGen" style="@style/Btn" android:layout_width="0dp" android:layout_height="54dp" android:layout_weight="1"
                android:layout_marginEnd="6dp" android:background="@drawable/btn_green" android:text="Generate QR PDF" android:textColor="#FFFFFF" />
            <Button android:id="@+id/btnLblBack" style="@style/Btn" android:layout_width="0dp" android:layout_height="54dp" android:layout_weight="1"
                android:layout_marginStart="6dp" android:background="@drawable/btn_dark" android:text="Back" android:textColor="#FFFFFF" />
        </LinearLayout>
    </LinearLayout>

    <!-- SETTINGS -->
    <ScrollView android:id="@+id/panelSettings" android:layout_width="match_parent" android:layout_height="match_parent"
        android:background="#091627" android:visibility="gone">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:background="#0E2746"
                android:padding="18dp" android:text="Settings" android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="18dp">
                <TextView style="@style/Lbl" android:text="VESSEL NAME" />
                <EditText android:id="@+id/etVessel" style="@style/Field" android:hint="Navigator Copernico" android:inputType="text" />
                <TextView style="@style/Lbl" android:layout_marginTop="16dp" android:text="SUPPLIER" />
                <EditText android:id="@+id/etSupplier" style="@style/Field" android:hint="PPG / Sigma Coatings" android:inputType="text" />
                <TextView style="@style/Lbl" android:layout_marginTop="16dp" android:text="REPORT RECIPIENTS (comma separated)" />
                <EditText android:id="@+id/etEmail" style="@style/Field" android:hint="master@..., supplier@..." android:inputType="textEmailAddress" />
                <Button android:id="@+id/btnSaveSettings" style="@style/Btn" android:layout_width="match_parent" android:layout_height="52dp"
                    android:layout_marginTop="12dp" android:layout_marginBottom="22dp" android:background="@drawable/btn_green" android:text="Save settings" android:textColor="#FFFFFF" />
                <TextView style="@style/Lbl" android:text="REPORTS FOLDER" />
                <TextView android:id="@+id/tvFolder" android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:paddingTop="4dp" android:paddingBottom="10dp" android:text="Default: Documents/PaintStock" android:textColor="#9FC0E8" android:textSize="13sp" />
                <Button android:id="@+id/btnChooseFolder" style="@style/Btn" android:layout_width="match_parent" android:layout_height="50dp"
                    android:layout_marginBottom="22dp" android:background="@drawable/btn_blue" android:text="Choose folder" android:textColor="#FFFFFF" />
                <Button android:id="@+id/btnResetSeed" style="@style/Btn" android:layout_width="match_parent" android:layout_height="50dp"
                    android:layout_marginBottom="22dp" android:background="@drawable/btn_red" android:text="Reset to factory list" android:textColor="#FFFFFF" />
                <Button android:id="@+id/btnSettingsBack" style="@style/Btn" android:layout_width="match_parent" android:layout_height="50dp"
                    android:background="@drawable/btn_dark" android:text="Back" android:textColor="#FFFFFF" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</FrameLayout>
